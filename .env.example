# Supabase (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# anon public key only — never put service_role here
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# --- Local dev ---
VITE_UCP_API_URL=http://127.0.0.1:8000
VITE_MCP_URL=http://127.0.0.1:8000/mcp

# --- Railway production (genko-portal service) ---
# VITE_UCP_API_URL=https://genko-platform-production.up.railway.app
# VITE_MCP_URL=https://genko-platform-production.up.railway.app/mcp
